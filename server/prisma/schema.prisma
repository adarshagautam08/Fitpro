generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  subscriptionPlans SubscriptionPlan[]

  // 🔗 Admin hierarchy
  adminId   String?
  admin     User?   @relation("AdminToUsers", fields: [adminId], references: [id])
  users     User[]  @relation("AdminToUsers")

  // 🔗 Workout
  trainerWorkouts WorkoutPlan[] @relation("TrainerWorkouts")
  assignments     WorkoutAssignment[]

  // 🔗 Sessions
  memberSessions  SessionBooking[] @relation("MemberSessions")
  trainerSessions SessionBooking[] @relation("TrainerSessions")

  // 🔗 Trainer availability
  availabilities  TrainerAvailability[]

  // 🔗 Business
  subscriptions Subscription[]
  attendances   Attendance[]
  progressLogs  Progress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TRAINER
  MEMBER
}

model SubscriptionPlan {
  id            String @id @default(cuid())
  name          String
  price         Float
  durationDays  Int
  adminId       String
  admin         User @relation(fields: [adminId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
}

model Subscription {
  id        String @id @default(cuid())
  userId    String
  planId    String
  startDate DateTime @default(now())
  endDate   DateTime
  status    SubscriptionStatus @default(ACTIVE)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model WorkoutPlan {
  id          String @id @default(cuid())
  title       String
  description String?
  trainerId   String
  trainer     User @relation("TrainerWorkouts", fields: [trainerId], references: [id], onDelete: Cascade)
  assignments WorkoutAssignment[]
  createdAt   DateTime @default(now())
}

model WorkoutAssignment {
  id         String @id @default(cuid())
  planId     String
  memberId   String
  plan       WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  member     User @relation(fields: [memberId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@index([memberId])
}

model Attendance {
  id     String @id @default(cuid())
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @default(now())

  @@index([userId])
}

model Progress {
  id        String @id @default(cuid())
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise  String
  weight    Float
  reps      Int
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model SessionBooking {
  id        String @id @default(cuid())
  memberId  String
  trainerId String
  member    User @relation("MemberSessions", fields: [memberId], references: [id], onDelete: Cascade)
  trainer   User @relation("TrainerSessions", fields: [trainerId], references: [id], onDelete: Cascade)
  date      DateTime
  status    SessionStatus
  createdAt DateTime @default(now())
}

model TrainerAvailability {
  id        String @id @default(cuid())
  trainerId String
  trainer   User @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  date      DateTime

  @@index([trainerId])
}

enum SessionStatus {
  BOOKED
  COMPLETED
  CANCELLED
}